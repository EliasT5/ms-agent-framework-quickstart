# API key. For a local LiteLLM proxy any non-empty value works (the proxy
# authenticates upstream using its own config). For a direct provider, use
# your real key.
OPENAI_API_KEY=sk-any-value-for-local-proxy

# Base URL — points at a local LiteLLM proxy.
# Start the proxy first:   litellm --model gpt-4o-mini --port 4000
OPENAI_BASE_URL=http://localhost:4000/v1

# Alternative endpoints (uncomment one and comment the line above):
# OPENAI_BASE_URL=https://api.openai.com/v1        # OpenAI direct
# OPENAI_BASE_URL=https://<your-provider>/v1       # any OpenAI-compatible endpoint
# (for OpenAI direct, remove the line entirely — it's the SDK default)

# Model ID. Whatever name your LiteLLM config (or provider) exposes.
# OpenAI direct: gpt-4o-mini. Other providers use their own names.
OPENAI_CHAT_COMPLETION_MODEL=gpt-4o-mini
